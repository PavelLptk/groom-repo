# Скопируйте в `.env` и при необходимости измените значения.

API_HOST=0.0.0.0
API_PORT=8010

# Секрет для подписи JWT (в продакшене — длинная случайная строка).
SECRET_KEY=dev-change-me-use-openssl-rand-hex-32

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
GUEST_MANAGE_TOKEN_EXPIRE_DAYS=30

# Через запятую: разрешённые origin'ы для CORS (фронт Vite).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Часовой пояс салона и сетка слотов (как на фронте).
SALON_TIMEZONE=Europe/Moscow
SLOT_START_TIMES=09:00,10:30,12:30,15:00,17:30,19:00
WORKDAY_OPEN=09:00
WORKDAY_CLOSE=21:00

# Минимальный запас до ближайшего слота (минуты).
MIN_BOOKING_LEAD_MINUTES=15

# Заглушка ссылки «оплаты» для pending-платежей.
MOCK_PAYMENT_BASE_URL=https://example.test/pay
